{
  "realm": "riding-platform",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": false,
  "roles": {
    "realm": [
      { "name": "rider" },
      { "name": "driver" },
      { "name": "platform-admin" },
      { "name": "ops-admin" },
      { "name": "support-agent" },
      { "name": "fraud-analyst" }
    ]
  },
  "clients": [
    {
      "clientId": "riding-platform-api",
      "name": "Riding Platform API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "defaultClientScopes": ["profile", "email", "roles"]
    },
    {
      "clientId": "riding-platform-web",
      "name": "Riding Platform Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "defaultClientScopes": ["profile", "email", "roles"]
    },
    {
      "clientId": "riding-platform-rider-mobile",
      "name": "Rider Mobile",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["profile", "email", "roles"]
    },
    {
      "clientId": "riding-platform-driver-mobile",
      "name": "Driver Mobile",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["profile", "email", "roles"]
    },
    {
      "clientId": "riding-platform-admin",
      "name": "Admin Console",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3001"
      ],
      "defaultClientScopes": ["profile", "email", "roles"]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect"
    }
  ]
}
